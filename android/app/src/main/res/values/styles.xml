<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">#06142E</item>
        <item name="android:navigationBarColor">#06142E</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="AppTheme.Launch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#06142E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/arch_quest_mark</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

</resources>
