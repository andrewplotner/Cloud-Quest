{
  "name": "cloud-quest",
  "private": true,
  "version": "0.8.8",
  "type": "module",
  "scripts": {
    "dev": "npm run build && vite dist --host 0.0.0.0",
    "build": "node scripts/build.mjs",
    "preview": "vite dist --host 0.0.0.0",
    "import:game": "node scripts/import-asset.mjs game",
    "import:splash": "node scripts/import-asset.mjs splash",
    "android:sync": "npm run build && node scripts/sync-android.mjs",
    "android:run": "npm run android:sync && ./android/gradlew -p android installDebug"
  },
  "devDependencies": {
    "vite": "^8.1.4"
  }
}
