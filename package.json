{
  "name": "cloud-quest",
  "private": true,
  "version": "0.9.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build && vite dist --host 0.0.0.0",
    "build": "node scripts/build.mjs",
    "preview": "vite dist --host 0.0.0.0",
    "import:game": "node scripts/import-asset.mjs game",
    "import:splash": "node scripts/import-asset.mjs splash",
    "android:sync": "npm run build && cap sync android && node scripts/verify-android-html.mjs",
    "android:open": "cap open android",
    "android:run": "npm run android:sync && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  }
}
